<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A4F7CFF" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="50%"
                android:centerY="35%"
                android:gradientRadius="80%"
                android:startColor="#B3FFFFFF"
                android:centerColor="#4D4F7CFF"
                android:endColor="#E64F7CFF" />
        </shape>
    </item>
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#33FFFFFF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
