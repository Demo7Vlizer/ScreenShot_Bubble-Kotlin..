<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:id="@+id/header_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_header_circle"
                android:elevation="0dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera"
                    android:importantForAccessibility="no"
                    app:tint="@color/primary_blue" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="24sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/service_inactive"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:background="@drawable/bg_dashboard_card"
                android:backgroundTint="@color/divider"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:layout_marginTop="14dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/permissions_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/permissions_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:id="@+id/card_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dashboard_card"
                android:elevation="0dp"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:id="@+id/overlay_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:importantForAccessibility="no"
                    android:background="@drawable/bg_header_circle"
                    android:backgroundTint="@color/primary_blue_light"
                    android:padding="10dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/primary_blue" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/overlay_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_overlay_title"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/overlay_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_overlay_desc"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="3dp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_overlay"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/permission_overlay_action"
                    android:textSize="13sp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_capture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dashboard_card"
                android:elevation="0dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/capture_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:importantForAccessibility="no"
                    android:background="@drawable/bg_header_circle"
                    android:backgroundTint="@color/primary_blue_light"
                    android:padding="10dp"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/primary_blue" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/capture_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_capture_title"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/capture_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_capture_desc"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="3dp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_capture"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/permission_capture_action"
                    android:textSize="13sp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/all_set_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/all_set"
                android:textSize="14sp"
                android:textColor="@color/success_green"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_dashboard_card"
                android:backgroundTint="@color/success_green_light"
                android:paddingVertical="14dp"
                android:layout_marginTop="10dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/stats_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_title"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/card_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_dashboard_card"
            android:elevation="0dp"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/stats_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="14dp"
                android:importantForAccessibility="no"
                android:background="@drawable/bg_header_circle"
                android:backgroundTint="@color/primary_blue_light"
                android:padding="10dp"
                android:src="@drawable/ic_check"
                app:tint="@color/primary_blue" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/stats_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/stats_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_title"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_service"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/service_start"
                android:textSize="13sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
